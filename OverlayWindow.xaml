<Window x:Class="SqwizzeySwitch.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sqwizzey Switch"
        Width="190" Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        Opacity="0">
    <Grid>
        <!-- Liquid bridge layer: a metaball outline drawn in window-local coords during
             app-switch transitions (window is temporarily resized to span both windows).
             Hidden the rest of the time; the card renders normally. -->
        <Path x:Name="LiquidPath" Visibility="Collapsed" IsHitTestVisible="False"
              Stretch="None" />

        <!-- CardRoot holds the glow halo + the card together so the spring animation
             (scale/translate) moves both as one. -->
        <Grid x:Name="CardRoot"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <!-- Order matters: the liquid "smear" rotates the card so the motion
                     axis aligns with X, stretches along it (squashes across), then
                     rotates back — a directional stretch along the flight path. The
                     spring scale + translate compose on top. -->
                <TransformGroup>
                    <RotateTransform x:Name="SmearRotNeg" Angle="0" />
                    <ScaleTransform  x:Name="SmearScale"  ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="SmearRotPos" Angle="0" />
                    <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="CardTranslate" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>

            <!-- Soft glow/shadow: a RadialGradientBrush halo (NOT a DropShadowEffect,
                 which leaves an opaque rectangle on this layered window). -->
            <Border x:Name="Glow"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />

            <Border x:Name="Card"
                    Width="110" Height="80"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Background="#CC1E1E1E">
                <TextBlock x:Name="LangText"
                           Text="EN"
                           FontFamily="Segoe UI"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Window>
